++++): MarginConfig {
++++    const allValues = processedData.flatMap(d => [d.cumulativeTotal, d.prevCumulativeTotal || 0]);
++++    const maxValue = d3.max(allValues) || 0;
++++    const minValue = d3.min(allValues) || 0;
