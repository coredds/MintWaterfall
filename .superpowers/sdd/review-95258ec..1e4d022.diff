+import * as d3 from 'd3';
+
+// Type definitions for hierarchical layout system
+export interface HierarchicalData {
+    id?: string;
+    name?: string;
+    value?: number;
+    data?: any;
+    children?: HierarchicalData[];
+}
+
+export interface LayoutOptions {
