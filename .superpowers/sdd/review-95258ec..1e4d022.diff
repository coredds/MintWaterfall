+-        if (typeof source === "string") {
+-            // URL or file path
+-            if (source.endsWith(".csv")) {
+-                rawData = await d3.csv(source);
+-            } else if (source.endsWith(".json")) {
+-                rawData = await d3.json(source);
+-            } else if (source.endsWith(".tsv")) {
+-                rawData = await d3.tsv(source);
