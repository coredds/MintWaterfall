-        enabled: true,
-        forces: {
-            collision: true,
-            positioning: true,
-            centering: false,
-            links: false
-        },
-        strength: {
-            collision: 0.8,
-            positioning: 0.6
-        },
-        duration: animationDuration
-    };
-}
