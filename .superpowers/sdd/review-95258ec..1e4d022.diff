++++            selection.attr("stroke-dasharray", "5,5");
++++        } else if (config.trendLineStyle === "dotted") {
++++            selection.attr("stroke-dasharray", "2,3");
++++        } else {
++++            selection.attr("stroke-dasharray", null);
