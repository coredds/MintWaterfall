++++    return {
++++        top: initialTopMargin + extraTopMarginNeeded + safetyBuffer,
++++        right: minRightMargin,
++++        bottom: baseMargin.bottom + extraBottomMargin + (hasNegativeValues ? safetyBuffer : 10),
++++        left: baseMargin.left,
++++    };
