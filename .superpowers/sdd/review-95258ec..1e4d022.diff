+-        if (item.value !== undefined) return item.value;
+-        if (item.stacks && Array.isArray(item.stacks)) {
+-            return item.stacks.reduce((sum: number, stack: any) => sum + (stack.value || 0), 0);
+-        }
+-        return 0;
+-    }
