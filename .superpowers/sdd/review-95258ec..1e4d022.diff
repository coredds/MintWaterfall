++++            .attr("width", barWidth);
++++
++++        stacks.exit()
++++            .transition()
++++            .duration(config.duration)
++++            .ease(config.ease)
++++            .attr("height", 0)
++++            .attr("y", yScale(0))
++++            .remove();
++++
++++        const stackLabels = group.selectAll(".stack-label").data(stackData.filter((s: any) => s.label));
++++
++++        const stackLabelsEnter = stackLabels.enter()
++++            .append("text")
++++            .attr("class", "stack-label")
++++            .attr("text-anchor", "middle")
++++            .attr("x", barWidth / 2)
++++            .attr("y", yScale(0))
++++            .style("opacity", 0);
