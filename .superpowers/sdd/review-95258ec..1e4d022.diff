-            .on('drag', (event, d) => {
-            const bar = d3__namespace.select(event.sourceEvent.target);
-            let newValue = d.value || 0;
-            // Handle axis constraints
-            if (config.axis === 'vertical' || config.axis === 'both') {
-                const newY = event.y;
-                newValue = yScale.invert(newY);
-                // Apply constraints
-                if (config.constraints) {
