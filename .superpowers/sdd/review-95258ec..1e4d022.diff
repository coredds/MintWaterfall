+-            // Already an array
+-            rawData = source;
+-        } else {
+-            throw new Error("Source must be a URL, file path, or data array");
+-        }
+-
+-        // Transform raw data to MintWaterfall format if needed
+-        return transformToWaterfallFormat(rawData, options);
+-        
+-    } catch (error) {
