++++            .attr("x", 0)
++++            .attr("width", barWidth)
++++            .attr("y", yScale(0))
++++            .attr("height", 0)
++++            .attr("fill", (stack: any) => stack.color);
++++
++++        (stacksEnter as any).merge(stacks)
++++            .transition()
++++            .duration(config.duration)
++++            .ease(config.ease)
++++            .attr("y", (stack: any) => stack.y)
++++            .attr("height", (stack: any) => stack.height)
