-function createWaterfallDragBehavior(onValueChange, constraints) {
-    return {
-        enabled: true,
-        axis: 'vertical',
-        constraints: {
-            minValue: constraints?.min,
-            maxValue: constraints?.max,
-            snapToGrid: true,
-            gridSize: 100 // Snap to hundreds
