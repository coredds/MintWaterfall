+-            .attr("x2", (d: any) => d.x1)
+-            .attr("y1", (d: any) => d.y)
+-            .attr("y2", (d: any) => d.y);
+-
+-        connectorsEnter.merge(connectors)
+-            .transition()
+-            .duration(duration)
+-            .ease(ease)
+-            .delay((d: any, i: number) => staggeredAnimations ? i * staggerDelay : 0)
+-            .attr("x1", (d: any) => d.x1)
+-            .attr("x2", (d: any) => d.x2)
+-            .attr("y1", (d: any) => d.y)
+-            .attr("y2", (d: any) => d.y)
+-            .style("opacity", 0.6);
