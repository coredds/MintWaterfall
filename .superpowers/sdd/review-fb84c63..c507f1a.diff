+++export function getBarWidth(scale: any, barCount: number, totalWidth: number): number {
+++    if (scale.bandwidth) {
+++        return scale.bandwidth();
+++    } else {
+++        const padding = 0.1;
+++        const availableWidth = totalWidth * (1 - padding);
+++        return availableWidth / barCount;
+++    }
+++}
