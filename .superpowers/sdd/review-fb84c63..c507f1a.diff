-        const budget = item[budgetField] || 0;
-        const variance = actual - budget;
-        
-        return {
-            label: item[categoryField],
-            stacks: [{
-                value: variance,
-                color: variance >= 0 ? '#2ecc71' : '#e74c3c',
-                label: `Variance: ${variance >= 0 ? '+' : ''}${d3.format('.2f')(variance)}`
-            }]
