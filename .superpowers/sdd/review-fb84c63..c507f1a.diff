+++
+++        const pessimisticPathEnter = pessimisticPath.enter()
+++            .append("path")
+++            .attr("class", "pessimistic-trend")
+++            .attr("fill", "none")
+++            .attr("stroke", "#e74c3c")
+++            .attr("stroke-width", 2)
